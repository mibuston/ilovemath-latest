<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>I Love Math | Premium Math Shortcuts</title>
  <meta
    name="description"
    content="Premium math shortcuts library for I Love Math with grade filters, quick tricks, worked examples, printable cheat sheet mode, and practice cards."
  />
  <link rel="icon" type="image/png" href="assets/logo.png" />
  <style>
    :root{
      --blue:#0f6fff;
      --blue2:#5ab9ff;
      --nav:#0d67d7;
      --dark:#123252;
      --text:#506982;
      --muted:#7b93ac;
      --white:#ffffff;
      --gold:#ffbf3f;
      --gold2:#ffe08f;
      --green:#20b66f;
      --green2:#69dca0;
      --red:#ef5350;
      --purple:#7f5cff;
      --purple2:#b099ff;
      --pink:#ff7cb4;
      --bg1:#eaf7ff;
      --bg2:#fff8eb;
      --glass:rgba(255,255,255,.80);
      --glass-strong:rgba(255,255,255,.93);
      --border:rgba(18,50,82,.08);
      --shadow:0 18px 42px rgba(18,50,82,.12);
      --shadow-hover:0 24px 56px rgba(18,50,82,.16);
      --radius-xl:30px;
      --radius-lg:22px;
      --radius-md:16px;
      --radius-sm:12px;
      --maxw:1360px;
      --transition:.22s ease;
    }

    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      font-family:Arial,Helvetica,sans-serif;
      color:var(--dark);
      background:
        radial-gradient(circle at top left, rgba(90,185,255,.18), transparent 28%),
        radial-gradient(circle at top right, rgba(255,191,63,.16), transparent 28%),
        linear-gradient(180deg,var(--bg1),#f7fbff 40%,var(--bg2));
    }

    a{text-decoration:none;color:inherit}
    button,input,select{font:inherit}
    button{border:none}

    .topbar{
      position:sticky;top:0;z-index:100;
      background:rgba(255,255,255,.84);
      backdrop-filter:blur(14px);
      border-bottom:1px solid var(--border);
    }
    .topbar-inner{
      max-width:var(--maxw);
      margin:auto;
      padding:14px 18px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:14px;
      flex-wrap:wrap;
    }
    .brand{
      display:flex;align-items:center;gap:14px;font-weight:800;color:var(--dark);
    }
    .brand img{
      width:58px;height:58px;border-radius:18px;object-fit:contain;background:#fff;padding:6px;box-shadow:var(--shadow);
    }
    .brand-text strong{display:block;font-size:20px}
    .brand-text small{display:block;color:var(--muted);font-weight:700;letter-spacing:.35px;margin-top:2px;font-size:12px}

    .nav-actions,.hero-actions,.filter-row,.mini-actions,.practice-actions,.cheat-actions{
      display:flex;flex-wrap:wrap;gap:12px;
    }

    .btn{
      display:inline-flex;align-items:center;justify-content:center;gap:8px;
      border-radius:16px;padding:13px 18px;font-weight:800;cursor:pointer;
      transition:transform var(--transition), box-shadow var(--transition), opacity var(--transition), background var(--transition);
      box-shadow:var(--shadow);user-select:none;
    }
    .btn:hover{transform:translateY(-2px);box-shadow:var(--shadow-hover)}
    .btn-primary{background:linear-gradient(135deg,var(--blue),var(--blue2));color:#fff}
    .btn-secondary{background:#fff;color:var(--dark)}
    .btn-gold{background:linear-gradient(135deg,var(--gold),var(--gold2));color:#5b4100}
    .btn-success{background:linear-gradient(135deg,var(--green),var(--green2));color:#fff}
    .btn-purple{background:linear-gradient(135deg,var(--purple),var(--purple2));color:#fff}
    .btn-ghost{background:rgba(255,255,255,.68);color:var(--dark);box-shadow:none;border:1px solid rgba(18,50,82,.08)}

    .wrap{max-width:var(--maxw);margin:auto;padding:22px 18px 60px}
    .section-space{margin-top:22px}

    .hero{
      display:grid;grid-template-columns:1.15fr .85fr;gap:22px;align-items:stretch;margin-top:16px;
    }

    .hero-card,.side-card,.panel,.shortcut-card,.summary-card,.practice-card,.cheat-card,.section-card,.spotlight-card,.mini-card,.tip-card{
      background:var(--glass);
      backdrop-filter:blur(10px);
      border:1px solid rgba(255,255,255,.62);
      box-shadow:var(--shadow);
      border-radius:var(--radius-xl);
    }
    .hero-card,.side-card,.panel,.shortcut-card,.summary-card,.practice-card,.cheat-card,.section-card,.spotlight-card,.tip-card{padding:24px}

    .label{
      display:inline-block;font-size:12px;font-weight:800;color:var(--nav);letter-spacing:.7px;text-transform:uppercase;margin-bottom:10px;
    }

    .hero h1{font-size:clamp(32px,4.5vw,58px);line-height:1.02;margin:0 0 14px}
    .hero p{font-size:18px;line-height:1.74;color:var(--text);margin:0 0 18px}
    .headline-accent{color:var(--blue)}
    .headline-gold{color:#d19100}
    .headline-purple{color:var(--purple)}

    .badges{display:flex;flex-wrap:wrap;gap:10px;margin:18px 0}
    .badge-pill{
      padding:10px 14px;border-radius:999px;background:#fff;color:var(--nav);font-weight:800;font-size:14px;border:1px solid rgba(15,111,255,.08);
    }

    .hero-grid,.stats-grid,.shortcut-grid,.mini-grid,.tip-grid{
      display:grid;gap:14px;
    }
    .hero-grid{grid-template-columns:1fr 1fr;margin-top:18px}
    .stats-grid{grid-template-columns:repeat(2,1fr);margin-top:18px}
    .shortcut-grid{grid-template-columns:repeat(3,1fr);margin-top:16px}
    .mini-grid{grid-template-columns:repeat(4,1fr)}
    .tip-grid{grid-template-columns:repeat(3,1fr);margin-top:14px}

    .summary-card{border-radius:22px;background:linear-gradient(180deg,#eef6ff,#ffffff);border:1px solid #dbe9f7}
    .summary-card h4,.tip-card h4{margin:0 0 8px;font-size:18px}
    .summary-card p,.tip-card p{margin:0;color:var(--text);font-size:14px;line-height:1.6}

    .mascot{
      min-height:250px;border-radius:24px;padding:22px;background:linear-gradient(180deg,#eef8ff,#fff7e8);display:flex;align-items:center;justify-content:center;text-align:center;border:1px dashed rgba(15,111,255,.18);position:relative;overflow:hidden;
    }
    .mascot::before,.mascot::after{content:"";position:absolute;border-radius:50%;filter:blur(6px);opacity:.55}
    .mascot::before{width:120px;height:120px;background:rgba(127,92,255,.14);top:-18px;right:-18px}
    .mascot::after{width:110px;height:110px;background:rgba(255,191,63,.18);bottom:-14px;left:-14px}
    .pi{width:148px;height:148px;margin:0 auto 14px;border-radius:36px;background:linear-gradient(135deg,#ffdd79,#ffbe3f);box-shadow:0 18px 35px rgba(255,191,63,.3);display:grid;place-items:center;font-size:64px}
    .mascot h3{margin:0 0 8px;font-size:26px}
    .mascot p{margin:0;color:var(--text);line-height:1.68;font-size:15px}

    .mini-card{
      padding:16px;border-radius:20px;text-align:center;background:rgba(255,255,255,.84);border:1px solid rgba(18,50,82,.06);
    }
    .mini-card strong{display:block;font-size:28px;margin-top:6px}
    .mini-card p{margin:8px 0 0;color:var(--text);font-size:14px;line-height:1.45}

    .panel h2,.section-card h2,.practice-card h2,.cheat-card h2,.spotlight-card h2{margin:0 0 14px;font-size:26px}

    .controls-grid{display:grid;grid-template-columns:1.3fr .9fr .9fr auto;gap:12px;align-items:end}
    .control{margin-bottom:0}
    .control label{display:block;margin-bottom:8px;font-weight:800;color:var(--dark)}
    .control select,.control input{
      width:100%;padding:14px 15px;border-radius:14px;border:1px solid #d9e7f6;background:#fff;outline:none;
      transition:border-color var(--transition), box-shadow var(--transition);
    }
    .control select:focus,.control input:focus{border-color:var(--blue);box-shadow:0 0 0 4px rgba(15,111,255,.1)}

    .section-card{overflow:hidden}
    .section-top{display:flex;justify-content:space-between;gap:14px;align-items:flex-start;flex-wrap:wrap}
    .section-name{font-size:30px;margin:0}
    .section-sub{color:var(--text);line-height:1.7;margin:0}

    .section-tabs{display:flex;flex-wrap:wrap;gap:10px;margin-top:16px}
    .tab-btn{
      padding:11px 14px;border-radius:999px;background:#fff;color:var(--dark);font-weight:800;border:1px solid #dcecff;cursor:pointer;
      transition:.2s ease;
    }
    .tab-btn.active{background:linear-gradient(135deg,var(--blue),var(--blue2));color:#fff;border-color:transparent}

    .shortcut-card{
      background:linear-gradient(180deg,#ffffff,#f8fbff);border:1px solid #e3edf7;position:relative;overflow:hidden;
      transition:transform var(--transition), box-shadow var(--transition), border var(--transition);
    }
    .shortcut-card:hover{transform:translateY(-3px);box-shadow:var(--shadow-hover);border-color:#cfe3ff}
    .shortcut-head{display:flex;justify-content:space-between;gap:12px;align-items:flex-start;margin-bottom:10px}
    .shortcut-title{margin:0;font-size:21px}
    .level-pill{
      padding:8px 12px;border-radius:999px;background:#eef6ff;color:var(--nav);font-size:12px;font-weight:800;white-space:nowrap;
    }
    .shortcut-rule,.shortcut-why,.shortcut-tip,.shortcut-practice{font-size:14px;line-height:1.7;color:var(--text);margin:10px 0}
    .shortcut-rule strong,.shortcut-why strong,.shortcut-tip strong,.shortcut-practice strong{color:var(--dark)}
    .example-box{
      margin-top:12px;padding:16px;border-radius:18px;background:#fff8ea;border:1px solid #f5dfaa;color:#5d4b14;line-height:1.7;font-weight:700;
    }
    .practice-mini{
      margin-top:14px;padding:14px;border-radius:16px;background:#eefcf4;border:1px solid #ccefdc;color:#124c31;font-weight:700;line-height:1.7;
    }

    .spotlight-box{
      padding:16px;border-radius:20px;background:#fff;border:1px solid #e3edf7;color:var(--text);line-height:1.75;font-size:14px;
    }
    .spotlight-box strong{color:var(--dark)}

    .practice-layout{display:grid;grid-template-columns:1fr .95fr;gap:18px;align-items:start}
    .practice-question{
      background:#fff;border:1px solid #e2edf7;border-radius:24px;padding:18px;position:relative;
    }
    .practice-question h4{margin:0 0 10px;font-size:24px;line-height:1.4}
    .practice-question p{margin:0 0 12px;color:var(--text);line-height:1.7}
    .practice-options{display:grid;gap:10px;margin-top:14px}
    .practice-option{
      width:100%;text-align:left;padding:15px 16px;border-radius:14px;border:1px solid #d7e5f5;background:#fff;cursor:pointer;font-weight:700;
      transition:transform var(--transition), border var(--transition), background var(--transition);
    }
    .practice-option:hover{transform:translateY(-1px);border-color:var(--blue)}
    .practice-option.correct{background:#eafaf1;border-color:var(--green)}
    .practice-option.wrong{background:#fff0ef;border-color:var(--red)}

    .feedback{margin-top:12px;font-weight:800;min-height:22px}
    .feedback.ok{color:var(--green)}
    .feedback.no{color:var(--red)}

    .cheat-sheet{
      background:linear-gradient(180deg,#fffef8,#fff7db);border:4px solid #f3d277;border-radius:28px;padding:28px 22px;position:relative;overflow:hidden;
    }
    .cheat-sheet::before,.cheat-sheet::after{content:"✦";position:absolute;font-size:38px;color:rgba(243,210,119,.55)}
    .cheat-sheet::before{top:18px;left:18px}
    .cheat-sheet::after{bottom:18px;right:18px}
    .cheat-sheet h3{font-size:36px;margin:6px 0 10px;text-align:center}
    .cheat-sheet p{margin:8px 0;line-height:1.7;color:var(--text);text-align:center}
    .cheat-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-top:20px}
    .cheat-item{background:#fff;border:1px solid #efdca4;border-radius:18px;padding:14px}
    .cheat-item strong{display:block;margin-bottom:6px}
    .cheat-item span{color:var(--text);line-height:1.6;font-size:14px}

    .footer-note{margin-top:28px;text-align:center;color:var(--text);line-height:1.7;font-size:14px}

    .hidden{display:none !important}

    @media print{
      body{background:#fff}
      .topbar,.hero-actions,.nav-actions,.filter-row,.practice-card,.spotlight-card,.footer-note,.btn,.tip-grid{display:none !important}
      .wrap{padding:0}
      .hero,.controls-grid,.practice-layout,.shortcut-grid,.cheat-grid,.mini-grid{grid-template-columns:1fr !important}
      .hero-card,.side-card,.panel,.shortcut-card,.summary-card,.cheat-card,.section-card{box-shadow:none;border:1px solid #ddd;background:#fff}
      .section-tabs{display:none}
      #shortcutGrid .shortcut-card{break-inside:avoid;margin-bottom:12px}
    }

    @media (max-width: 1180px){
      .hero,.practice-layout{grid-template-columns:1fr}
      .controls-grid{grid-template-columns:1fr 1fr}
      .shortcut-grid{grid-template-columns:repeat(2,1fr)}
      .mini-grid,.tip-grid{grid-template-columns:repeat(2,1fr)}
    }
    @media (max-width: 820px){
      .hero-grid,.stats-grid,.shortcut-grid,.mini-grid,.tip-grid,.cheat-grid,.controls-grid{grid-template-columns:1fr}
      .wrap{padding:18px 14px 50px}
      .hero-card,.side-card,.panel,.shortcut-card,.summary-card,.practice-card,.cheat-card,.section-card,.spotlight-card,.tip-card{padding:18px}
      .nav-actions,.hero-actions,.filter-row,.practice-actions,.mini-actions,.cheat-actions{flex-direction:column}
      .btn{width:100%}
      .section-name{font-size:26px}
    }
  </style>
</head>
<body>
  <div class="topbar">
    <div class="topbar-inner">
      <div class="brand">
        <img src="assets/logo.png" alt="I Love Math logo" onerror="this.style.display='none'">
        <div class="brand-text">
          <strong>I Love Math</strong>
          <small>Premium Math Shortcuts</small>
        </div>
      </div>

      <nav class="nav-actions">
        <a href="index.html" class="btn btn-secondary">Home</a>
        <a href="worksheets.html" class="btn btn-secondary">Worksheets</a>
        <a href="game.html" class="btn btn-secondary">Games</a>
        <a href="puzzle.html" class="btn btn-secondary">Puzzles</a>
        <button type="button" class="btn btn-primary" id="jumpLibraryBtn">Open Shortcut Library</button>
      </nav>
    </div>
  </div>

  <div class="wrap">
    <section class="hero">
      <div class="hero-card">
        <div>
          <div class="label">Premium Shortcut Library</div>
          <h1>
            Learn <span class="headline-accent">math faster</span> with
            <span class="headline-purple">smart tricks</span>,
            <span class="headline-gold">clear examples</span>, and mini practice
          </h1>
          <p>
            This page gives students and parents a premium shortcut library for faster thinking,
            stronger number sense, and easier review. Every shortcut includes a simple rule,
            a worked example, a reason why it works, and a quick way to practice it.
          </p>

          <div class="badges">
            <span class="badge-pill">K–6 Shortcuts</span>
            <span class="badge-pill">Worked Examples</span>
            <span class="badge-pill">Why It Works</span>
            <span class="badge-pill">Quick Practice</span>
            <span class="badge-pill">Printable Cheat Sheet</span>
            <span class="badge-pill">Parent Friendly</span>
          </div>

          <div class="hero-actions">
            <button class="btn btn-primary" id="startExploringBtn">Start Exploring</button>
            <button class="btn btn-gold" id="printCheatBtn">Print Cheat Sheet</button>
            <button class="btn btn-purple" id="jumpPracticeBtn">Practice a Shortcut</button>
          </div>

          <div class="hero-grid">
            <div class="summary-card">
              <div class="label">Student Benefit</div>
              <h4>Think faster, not harder</h4>
              <p>Students learn quick mental strategies like making 10, doubling, using friendly numbers, and spotting patterns.</p>
            </div>
            <div class="summary-card">
              <div class="label">Parent Benefit</div>
              <h4>Easy to review at home</h4>
              <p>Parents can quickly explain each trick using the simple rule, example, and mini practice prompt in every card.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="side-card">
        <div class="mascot">
          <div>
            <div class="pi">🧠</div>
            <h3>Professor Pi</h3>
            <p>
              “Math shortcuts should make thinking clearer, not confusing.
              Use them to build understanding, speed, and confidence.”
            </p>
          </div>
        </div>

        <div class="stats-grid">
          <div class="mini-card">
            <span class="label">Shortcut Cards</span>
            <strong id="statShortcuts">24</strong>
            <p>Carefully organized premium tricks</p>
          </div>
          <div class="mini-card">
            <span class="label">Grade Bands</span>
            <strong>4</strong>
            <p>K–2, 3–4, 5–6, all grades</p>
          </div>
          <div class="mini-card">
            <span class="label">Mini Practice</span>
            <strong>24</strong>
            <p>Every card includes a quick try-it</p>
          </div>
          <div class="mini-card">
            <span class="label">Cheat Sheet</span>
            <strong>Print</strong>
            <p>Ready for home or classroom review</p>
          </div>
        </div>
      </div>
    </section>

    <section class="spotlight-card section-space">
      <div class="label">Shortcut Spotlight</div>
      <h2>How to use this page</h2>
      <div class="mini-grid" style="margin-top:10px;">
        <div class="mini-card">
          <span class="label">Step 1</span>
          <strong>Choose</strong>
          <p>Pick a grade band or search a keyword like fractions, multiply, or percent.</p>
        </div>
        <div class="mini-card">
          <span class="label">Step 2</span>
          <strong>Read</strong>
          <p>Look at the shortcut rule and the worked example first.</p>
        </div>
        <div class="mini-card">
          <span class="label">Step 3</span>
          <strong>Understand</strong>
          <p>Use the “Why it works” section so the trick makes sense.</p>
        </div>
        <div class="mini-card">
          <span class="label">Step 4</span>
          <strong>Practice</strong>
          <p>Try the quick prompt or use the practice area below.</p>
        </div>
      </div>
    </section>

    <section class="panel section-space" id="librarySection">
      <div class="label">Filter the Library</div>
      <h2>Find the right shortcut fast</h2>
      <div class="controls-grid">
        <div class="control">
          <label for="searchInput">Search Shortcut</label>
          <input id="searchInput" type="text" placeholder="Type a keyword like doubles, fractions, percent, or PEMDAS" />
        </div>
        <div class="control">
          <label for="gradeFilter">Grade Band</label>
          <select id="gradeFilter">
            <option value="all">All Grades</option>
            <option value="K-2">K–2</option>
            <option value="3-4">3–4</option>
            <option value="5-6">5–6</option>
            <option value="All">All Levels</option>
          </select>
        </div>
        <div class="control">
          <label for="categoryFilter">Category</label>
          <select id="categoryFilter">
            <option value="all">All Categories</option>
          </select>
        </div>
        <button class="btn btn-secondary" id="clearFiltersBtn">Clear Filters</button>
      </div>
    </section>

    <section class="section-card section-space">
      <div class="section-top">
        <div>
          <div class="label">Shortcut Library</div>
          <h2 class="section-name">Premium Math Shortcut Cards</h2>
          <p class="section-sub">Use the tabs or filters to move through the shortcut library. Every card has a rule, example, explanation, and a quick practice prompt.</p>
        </div>
      </div>

      <div class="section-tabs" id="sectionTabs"></div>
      <div class="shortcut-grid" id="shortcutGrid"></div>
    </section>

    <section class="practice-card section-space" id="practiceSection">
      <div class="label">Try One Now</div>
      <h2>Practice a shortcut</h2>
      <div class="practice-layout">
        <div class="practice-question">
          <h4 id="practiceQuestionTitle">Choose a practice card</h4>
          <p id="practiceQuestionText">Select a shortcut from the list on the right to load a quick question.</p>
          <div class="practice-options" id="practiceOptions"></div>
          <div class="feedback" id="practiceFeedback"></div>
          <div class="practice-actions">
            <button class="btn btn-secondary" id="newPracticeBtn">New Practice</button>
            <button class="btn btn-primary" id="showAnswerBtn">Show Explanation</button>
          </div>
        </div>

        <div>
          <div class="spotlight-box">
            <strong>Shortcut in focus</strong><br>
            <span id="practiceFocusText">No shortcut selected yet.</span>
          </div>
          <div class="tip-grid">
            <div class="tip-card">
              <h4>Use shortcuts wisely</h4>
              <p>Shortcuts should support understanding. They work best when students also know the main method.</p>
            </div>
            <div class="tip-card">
              <h4>Practice in small bursts</h4>
              <p>Reviewing 3–5 shortcuts often is better than trying to memorize everything at once.</p>
            </div>
            <div class="tip-card">
              <h4>Say the rule aloud</h4>
              <p>Students remember faster when they explain the trick in their own words.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="cheat-card section-space" id="cheatSheetSection">
      <div class="label">Printable Review</div>
      <h2>Quick cheat sheet</h2>
      <div class="cheat-sheet">
        <h3>Math Shortcut Cheat Sheet</h3>
        <p>Fast review for students, parents, and classroom practice.</p>
        <div class="cheat-grid" id="cheatGrid"></div>
        <div class="cheat-actions" style="justify-content:center;margin-top:18px;">
          <button class="btn btn-gold" id="printSheetBtn">Print This Sheet</button>
        </div>
      </div>
    </section>

    <div class="footer-note">
      © I Love Math • Premium Math Shortcuts Library • Built for quick review, stronger number sense, and easier home practice.
    </div>
  </div>

  <script>
    const shortcuts = [
      {
        id:"make10",
        title:"Make 10 First",
        grade:"K-2",
        category:"Addition",
        tags:["addition","make 10","mental math","number bonds"],
        rule:"If a number is close to 10, break the other number apart to make 10 first.",
        example:"8 + 5 = 8 + 2 + 3 = 10 + 3 = 13",
        why:"Making 10 first helps the brain add faster because 10 is a friendly number.",
        tip:"Look for numbers like 8 or 9 and ask, “How much more to make 10?”",
        practicePrompt:"What is 9 + 6 using make 10 first?",
        practiceOptions:["14","15","16","17"],
        practiceAnswer:"15",
        practiceExplain:"9 needs 1 to make 10. Break 6 into 1 and 5. So 9 + 6 = 10 + 5 = 15."
      },
      {
        id:"doubles",
        title:"Use Doubles Facts",
        grade:"K-2",
