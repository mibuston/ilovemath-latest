    const sectionOrder = ["All", "Addition", "Subtraction", "Multiplication", "Division", "Number Tricks", "Patterns", "Place Value", "Fractions", "Decimals", "Percents", "Geometry", "Operations"];

    const searchInput = document.getElementById("searchInput");
    const gradeFilter = document.getElementById("gradeFilter");
    const categoryFilter = document.getElementById("categoryFilter");
    const sectionTabs = document.getElementById("sectionTabs");
    const shortcutGrid = document.getElementById("shortcutGrid");
    const cheatGrid = document.getElementById("cheatGrid");
    const practiceQuestionTitle = document.getElementById("practiceQuestionTitle");
    const practiceQuestionText = document.getElementById("practiceQuestionText");
    const practiceOptions = document.getElementById("practiceOptions");
    const practiceFeedback = document.getElementById("practiceFeedback");
    const practiceFocusText = document.getElementById("practiceFocusText");
    const statShortcuts = document.getElementById("statShortcuts");

    const jumpLibraryBtn = document.getElementById("jumpLibraryBtn");
    const startExploringBtn = document.getElementById("startExploringBtn");
    const jumpPracticeBtn = document.getElementById("jumpPracticeBtn");
    const printCheatBtn = document.getElementById("printCheatBtn");
    const printSheetBtn = document.getElementById("printSheetBtn");
    const clearFiltersBtn = document.getElementById("clearFiltersBtn");
    const newPracticeBtn = document.getElementById("newPracticeBtn");
    const showAnswerBtn = document.getElementById("showAnswerBtn");

    let activeSection = "All";
    let currentPractice = null;
    let practiceAnswered = false;

    function init(){
      statShortcuts.textContent = shortcuts.length;
      buildCategoryFilter();
      buildSectionTabs();
      renderShortcutCards();
      renderCheatSheet();
      wireEvents();
    }

    function buildCategoryFilter(){
      const categories = [...new Set(shortcuts.map(item => item.category))].sort();
      categoryFilter.innerHTML = `<option value="all">All Categories</option>` + categories.map(cat => `<option value="${cat}">${cat}</option>`).join("");
    }

    function buildSectionTabs(){
      const available = sectionOrder.filter(section => section === "All" || shortcuts.some(item => item.category === section));
      sectionTabs.innerHTML = available.map(section => `
        <button class="tab-btn ${section === activeSection ? "active" : ""}" data-section="${section}">${section}</button>
      `).join("");

      document.querySelectorAll(".tab-btn").forEach(btn => {
        btn.addEventListener("click", () => {
          activeSection = btn.dataset.section;
          buildSectionTabs();
          renderShortcutCards();
        });
      });
    }

    function getFilteredShortcuts(){
      const query = searchInput.value.trim().toLowerCase();
      const grade = gradeFilter.value;
      const category = categoryFilter.value;

      return shortcuts.filter(item => {
        const matchSection = activeSection === "All" || item.category === activeSection;
        const matchGrade = grade === "all" || item.grade === grade || item.grade === "All" || (grade === "3-4" && item.grade === "3-6") || (grade === "5-6" && item.grade === "3-6");
        const matchCategory = category === "all" || item.category === category;
        const haystack = [item.title, item.category, item.grade, item.rule, item.example, item.why, item.tip, ...(item.tags || [])].join(" ").toLowerCase();
        const matchQuery = !query || haystack.includes(query);
        return matchSection && matchGrade && matchCategory && matchQuery;
      });
    }

    function renderShortcutCards(){
      const items = getFilteredShortcuts();
      if(items.length === 0){
        shortcutGrid.innerHTML = `
          <div class="shortcut-card" style="grid-column:1/-1;">
            <h3 class="shortcut-title">No shortcuts found</h3>
            <p class="shortcut-rule">Try another search word or clear the filters.</p>
          </div>
        `;
        return;
      }

      shortcutGrid.innerHTML = items.map(item => `
        <article class="shortcut-card">
          <div class="shortcut-head">
            <h3 class="shortcut-title">${item.title}</h3>
            <span class="level-pill">${item.grade}</span>
          </div>
          <div class="label">${item.category}</div>
          <div class="shortcut-rule"><strong>Shortcut:</strong> ${item.rule}</div>
          <div class="example-box"><strong>Example:</strong> ${item.example}</div>
          <div class="shortcut-why"><strong>Why it works:</strong> ${item.why}</div>
          <div class="shortcut-tip"><strong>Tip:</strong> ${item.tip}</div>
          <div class="practice-mini"><strong>Try it:</strong> ${item.practicePrompt}</div>
          <div class="mini-actions" style="margin-top:14px;">
            <button class="btn btn-secondary use-practice-btn" data-id="${item.id}">Practice This</button>
          </div>
        </article>
      `).join("");

      document.querySelectorAll(".use-practice-btn").forEach(btn => {
        btn.addEventListener("click", () => {
          const item = shortcuts.find(x => x.id === btn.dataset.id);
          loadPractice(item);
          document.getElementById("practiceSection").scrollIntoView({behavior:"smooth"});
        });
      });
    }

    function renderCheatSheet(){
      const picks = [
        "make10","doubles","nearDoubles","countUpSub","multBy5","multBy9","divideUseMult","sameDenominator","decimalPlace","percent100","areaRowsCols","pemdas"
      ].map(id => shortcuts.find(item => item.id === id)).filter(Boolean);

      cheatGrid.innerHTML = picks.map(item => `
        <div class="cheat-item">
          <strong>${item.title}</strong>
          <span>${item.rule}<br><em>${item.example}</em></span>
        </div>
      `).join("");
    }

    function loadPractice(item){
      currentPractice = item;
      practiceAnswered = false;
      practiceQuestionTitle.textContent = item.title;
      practiceQuestionText.textContent = item.practicePrompt;
      practiceFocusText.textContent = `${item.title} • ${item.category} • ${item.grade}`;
      practiceFeedback.textContent = "";
      practiceFeedback.className = "feedback";

      practiceOptions.innerHTML = item.practiceOptions.map(option => `
        <button class="practice-option" data-option="${option}">${option}</button>
      `).join("");

      document.querySelectorAll(".practice-option").forEach(btn => {
        btn.addEventListener("click", () => checkPractice(btn.dataset.option));
      });
    }

    function checkPractice(selected){
      if(!currentPractice || practiceAnswered) return;
      practiceAnswered = true;

      document.querySelectorAll(".practice-option").forEach(btn => {
        if(btn.dataset.option === currentPractice.practiceAnswer) btn.classList.add("correct");
        if(btn.dataset.option === selected && selected !== currentPractice.practiceAnswer) btn.classList.add("wrong");
        btn.disabled = true;
      });

      if(selected === currentPractice.practiceAnswer){
        practiceFeedback.textContent = `Correct! ${currentPractice.practiceExplain}`;
        practiceFeedback.className = "feedback ok";
      }else{
        practiceFeedback.textContent = `Not quite. ${currentPractice.practiceExplain}`;
        practiceFeedback.className = "feedback no";
      }
    }

    function newRandomPractice(){
      const filtered = getFilteredShortcuts();
      const pool = filtered.length ? filtered : shortcuts;
      const next = pool[Math.floor(Math.random() * pool.length)];
      loadPractice(next);
    }

    function wireEvents(){
      [searchInput, gradeFilter, categoryFilter].forEach(el => {
        el.addEventListener("input", renderShortcutCards);
        el.addEventListener("change", renderShortcutCards);
      });

      clearFiltersBtn.addEventListener("click", () => {
        searchInput.value = "";
        gradeFilter.value = "all";
        categoryFilter.value = "all";
        activeSection = "All";
        buildSectionTabs();
        renderShortcutCards();
      });

      jumpLibraryBtn.addEventListener("click", () => document.getElementById("librarySection").scrollIntoView({behavior:"smooth"}));
      startExploringBtn.addEventListener("click", () => document.getElementById("librarySection").scrollIntoView({behavior:"smooth"}));
      jumpPracticeBtn.addEventListener("click", () => document.getElementById("practiceSection").scrollIntoView({behavior:"smooth"}));
      printCheatBtn.addEventListener("click", () => window.print());
      printSheetBtn.addEventListener("click", () => window.print());

      newPracticeBtn.addEventListener("click", newRandomPractice);
      showAnswerBtn.addEventListener("click", () => {
        if(!currentPractice) return;
        practiceFeedback.textContent = currentPractice.practiceExplain;
        practiceFeedback.className = "feedback ok";
      });
    }

    init();
    newRandomPractice();
  </script>
